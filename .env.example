# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/data-stream
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Docker Compose database defaults
POSTGRES_USER=datalens
POSTGRES_PASSWORD=datalens
POSTGRES_DB=datalens

# Docker Compose backend defaults
DATABASE_URL=postgresql+asyncpg://datalens:datalens@db:5432/datalens
JWT_SECRET=changeme-in-production

# Sentry (optional — leave empty to disable telemetry)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Demo mode (set to true for the public demo — bypasses auth)
NEXT_PUBLIC_DEMO_MODE=false
