# Frontend browser origin. Keep localhost for the default single-host Docker flow.
# In production, point this at the public HTTPS origin that serves DataLens.
# No trailing /api or /api/v1; the frontend owns the "/api" path prefix.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Frontend browser websocket URL. Match the public origin above in production.
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/data-stream
# Backend-only Ollama base URL. Change this if Ollama runs on another host.
OLLAMA_URL=http://localhost:11434
# Ollama model name used by local AI features.
OLLAMA_MODEL=llama3.2

# Bundled PostgreSQL username for the Docker Compose database container.
POSTGRES_USER=datalens
# Bundled PostgreSQL password. Replace with a strong secret in production.
POSTGRES_PASSWORD=datalens
# Bundled PostgreSQL database name.
POSTGRES_DB=datalens

# Backend SQLAlchemy URL. Keep host `db` for the bundled Docker Compose network.
DATABASE_URL=postgresql+asyncpg://datalens:datalens@db:5432/datalens

# JWT_SECRET is REQUIRED. Leave this blank and set it to a strong random
# value before starting the app. Missing, empty, or known-weak values will
# fail-fast on boot in every environment except local development.
# Generate one with:
#   openssl rand -hex 32
JWT_SECRET=

# Browser Sentry DSN. Leave empty to disable frontend error reporting.
NEXT_PUBLIC_SENTRY_DSN=
# Backend Sentry DSN. Leave empty to disable backend error reporting.
SENTRY_DSN=
# Frontend Sentry environment label, for example `production`.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Frontend traces sample rate between 0 and 1.
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Sentry organization slug, used for release automation.
SENTRY_ORG=
# Sentry project slug, used for release automation.
SENTRY_PROJECT=
# Sentry auth token, used for release automation and source map upload.
SENTRY_AUTH_TOKEN=

# Public demo toggle. Set to true only when you want auth disabled for a demo.
NEXT_PUBLIC_DEMO_MODE=false
