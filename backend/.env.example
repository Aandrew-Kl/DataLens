# FastAPI runtime mode. Development allows placeholder JWT secrets.
ENVIRONMENT=development

# Async SQLAlchemy connection string for the backend database.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/datalens

# JWT signing configuration. Change the secret before any non-development deploy.
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000

# External service endpoints used by the backend.
OLLAMA_URL=http://localhost:11434

# App metadata and logging.
LOG_LEVEL=INFO
APP_VERSION=1.0.0

# File handling defaults.
UPLOADS_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# ── Frontend (Next.js) ─────────────────────────────────────────────
# Base URL for the FastAPI backend (used by the Next.js frontend).
NEXT_PUBLIC_API_URL=http://localhost:8000
# WebSocket URL for real-time data streaming.
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/data-stream
