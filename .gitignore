# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/

# next.js
/.next/
/out/
docs-site/.next/
docs-site/out/
docs-site/node_modules/

# production
/build

# misc
.DS_Store
*.pem

# python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Screenshot generation artifacts (optional — can be committed)
# docs-site/public/images/screenshots/
backend/.coverage
